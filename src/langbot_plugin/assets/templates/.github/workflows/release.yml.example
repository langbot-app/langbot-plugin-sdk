{% raw %}name: Release Plugin

on:
  push:
    branches:
      - main
    paths:
      - "manifest.yaml"
  workflow_dispatch:
    inputs:
      release:
        description: "Create a new release"
        required: true
        type: boolean
        default: true

permissions:
  contents: write

jobs:
  release:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Get metadata
        id: meta
        run: |
          PLUGIN_NAME=$(yq '.metadata.name' manifest.yaml)
          VERSION=$(yq '.metadata.version' manifest.yaml)
          echo "name=$PLUGIN_NAME" >> "$GITHUB_OUTPUT"
          echo "version=$VERSION" >> "$GITHUB_OUTPUT"
          echo "tag=v$VERSION" >> "$GITHUB_OUTPUT"
          echo "artifact=${PLUGIN_NAME}-${VERSION}" >> "$GITHUB_OUTPUT"

      - name: Check release exists
        id: check
        run: |
          if gh release view "$TAG" --json tagName > /dev/null 2>&1; then
            echo "exists=true" >> "$GITHUB_OUTPUT"
          else
            echo "exists=false" >> "$GITHUB_OUTPUT"
          fi
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          TAG: ${{ steps.meta.outputs.tag }}

      - name: Package plugin
        if: ${{ steps.check.outputs.exists == 'false' && (github.event_name == 'push' || (github.event_name == 'workflow_dispatch' && inputs.release == true)) }}
        run: |
          zip -r "${{ steps.meta.outputs.artifact }}.zip" . \
            -x ".git/*" \
            -x ".github/*" \
            -x ".vscode/*" \
            -x "__pycache__/*" \
            -x "*.pyc" \
            -x ".env" \
            -x ".env.example"

      - name: Create release
        if: ${{ steps.check.outputs.exists == 'false' && (github.event_name == 'push' || (github.event_name == 'workflow_dispatch' && inputs.release == true)) }}
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ steps.meta.outputs.tag }}
          name: ${{ steps.meta.outputs.artifact }}
          body: |
            ## ${{ steps.meta.outputs.artifact }}

            ### Installation
            Download `${{ steps.meta.outputs.artifact }}.zip` and install via LangBot plugin marketplace.
          files: ${{ steps.meta.outputs.artifact }}.zip
          draft: false
          prerelease: false
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
{% endraw %}